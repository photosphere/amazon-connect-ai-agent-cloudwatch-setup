# Connect AI Agent 日志排查 - 数据源配置(模板)
#
# 复制本文件为 config.env 并填入你自己的日志组 ARN:
#   cp config.env.example config.env
#
# 两个参数都是 CloudWatch Logs 日志组的 ARN(可带结尾的 :*)。
# 脚本会从 ARN 中解析出 region 与日志组名，分别拉取日志后关联展示。

# Amazon Connect AI Agent 的 CloudWatch 日志组 ARN
# (由 setup-connect-ai-agent-logs.sh 配置投递的日志组)
CONNECT_AI_AGENT_LOG_ARN="arn:aws:logs:<region>:<account-id>:log-group:/aws/connect/ai-agent-logs:*"

# Bedrock AgentCore Gateway 的 CloudWatch 日志组 ARN
# (承载 MCP server / 工具调用的网关应用日志)
BEDROCK_AGENTCORE_GATEWAY_LOG_ARN="arn:aws:logs:<region>:<account-id>:log-group:/aws/vendedlogs/bedrock-agentcore/gateway/APPLICATION_LOGS/<your-gateway>:*"

# ---------------------------------------------------------------------------
# CSAT 满意度评分字段(可选)
# ---------------------------------------------------------------------------
# 页面「CSAT 满意度评分」列取自 Amazon Connect 联系人属性(Contact Attributes)
# 里的某个自定义键。不同账号/Contact Flow 写入的键名可能不同，这里可自定义，
# 不写死。留空则使用默认值 botevaluation。
#   - 供 fetch-connect-contact-details.py 生成 connect-enrich.js 时使用
#   - CloudFront 部署下也会注入前端(aws-config.js)供浏览器实时读取
CSAT_ATTRIBUTE_KEY="botevaluation"

# ---------------------------------------------------------------------------
# 按需翻译配置(可选)
# ---------------------------------------------------------------------------
# 页面里每个 Contact 旁边有「翻译」按钮，点击后会用下面配置的 Amazon Bedrock
# Nova 模型，把该 Contact 里客户/机器人的对话翻译成目标语种(保留原文并高亮译文)。
# 翻译在本地预览服务器上按需调用 Bedrock，需要 aws CLI(已配置凭证)。

# 用于翻译的 Bedrock Nova 模型 ID
NOVA_TRANSLATE_MODEL_ID="amazon.nova-lite-v1:0"

# 调用 Bedrock 的 region;留空则依次回退到
# AWS_REGION / AWS_DEFAULT_REGION / aws configure 的 region / us-east-1
NOVA_TRANSLATE_REGION=""

# 默认目标翻译语种(页面上也可切换),例如: 中文 / 英语 / 日语
TRANSLATE_TARGET_LANG="英语"

# --- Nova 模型推理参数(inferenceConfig) ---
# 单次翻译生成的最大 token 数。文本较长/译文被截断时可调大。
NOVA_TRANSLATE_MAX_TOKENS="2000"

# 采样温度(0.0~1.0)。翻译建议用 0 让结果更稳定、可复现。
NOVA_TRANSLATE_TEMPERATURE="0.0"

# 核采样 top_p(0.0~1.0)。一般保持默认即可。
NOVA_TRANSLATE_TOP_P="0.9"
