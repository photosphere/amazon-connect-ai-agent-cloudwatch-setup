# Connect AI Agent 日志排查 - 数据源配置(模板)
#
# 复制本文件为 config.env 并填入你自己的日志组 ARN:
#   cp config.env.example config.env
#
# 两个参数都是 CloudWatch Logs 日志组的 ARN(可带结尾的 :*)。
# 脚本会从 ARN 中解析出 region 与日志组名，分别拉取日志后关联展示。

# Amazon Connect AI Agent 的 CloudWatch 日志组 ARN
# (由 setup-connect-ai-agent-logs.sh 配置投递的日志组)
CONNECT_AI_AGENT_LOG_ARN="arn:aws:logs:<region>:<account-id>:log-group:/aws/connect/ai-agent-logs:*"

# Bedrock AgentCore Gateway 的 CloudWatch 日志组 ARN
# (承载 MCP server / 工具调用的网关应用日志)
BEDROCK_AGENTCORE_GATEWAY_LOG_ARN="arn:aws:logs:<region>:<account-id>:log-group:/aws/vendedlogs/bedrock-agentcore/gateway/APPLICATION_LOGS/<your-gateway>:*"
